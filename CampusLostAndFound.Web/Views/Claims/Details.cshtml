@model CampusLostAndFound.Web.Models.DTOs.ClaimDto

@{
    ViewData["Title"] = "Claim Details";
}

<div class="container py-4">

    <h2 class="mb-4">Claim Details</h2>

    <div class="card">
        <div class="card-header d-flex justify-content-between">

            <h5>
                Claim for: @Model.ItemTitle
            </h5>

            @switch (Model.Status)
            {
                case CampusLostAndFound.Web.Models.Enums.ClaimStatus.Pending:
                    <span class="badge bg-warning text-dark">Pending</span>
                    break;

                case CampusLostAndFound.Web.Models.Enums.ClaimStatus.Approved:
                    <span class="badge bg-success">Approved</span>
                    break;

                case CampusLostAndFound.Web.Models.Enums.ClaimStatus.Rejected:
                    <span class="badge bg-danger">Rejected</span>
                    break;
            }

        </div>

        <div class="card-body">

            <h6>Description</h6>
            <p>@Model.Description</p>

            <hr />

            <p>
                <strong>Submitted:</strong>
                @Model.CreatedAt.ToString("MMM dd, yyyy")
            </p>

            @if (!string.IsNullOrEmpty(Model.AdminNotes))
            {
                <div class="alert alert-info">
                    <strong>Admin Notes:</strong><br />
                    @Model.AdminNotes
                </div>
            }

            <a asp-controller="Items"
               asp-action="Details"
               asp-route-id="@Model.ItemId"
               class="btn btn-outline-primary">
                View Item
            </a>

            <a asp-action="Index"
               class="btn btn-secondary">
                Back
            </a>

        </div>
    </div>

</div>