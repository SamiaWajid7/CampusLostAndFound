@model List<CampusLostAndFound.Web.Models.DTOs.AuditLogListDto>
@{
    ViewData["Title"] = "Audit Logs";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Audit Logs</h1>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Timestamp</th>
                    <th>User</th>
                    <th>Action</th>
                    <th>Entity</th>
                    <th>Details</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model)
                {
                    <tr>
                        <td>@log.CreatedAt.ToString("MMM dd, yyyy h:mm tt")</td>
                        <td>@log.UserName</td>
                        <td>
                            <span class="badge @GetActionBadgeClass(log.Action)">@log.Action</span>
                        </td>
                        <td>
                            @log.EntityType
                            <small class="text-muted">(#@log.EntityId)</small>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(log.Details))
                            {
                                <span title="@log.Details">
                                    @(log.Details.Length > 50 ? log.Details.Substring(0, 50) + "..." : log.Details)
                                </span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@functions {
    string GetActionBadgeClass(string action)
    {
        return action.ToLower() switch
        {
            "create" or "created" => "bg-success",
            "update" or "updated" => "bg-info",
            "delete" or "deleted" => "bg-danger",
            "approve" or "approved" => "bg-success",
            "reject" or "rejected" => "bg-warning text-dark",
            "login" => "bg-primary",
            "logout" => "bg-secondary",
            _ => "bg-secondary"
        };
    }
}
