@using CampusLostAndFound.Web.Models.DTOs
@using CampusLostAndFound.Web.Models.Enums
@model List<ClaimDto>
@{
    ViewData["Title"] = "Pending Claims";
    Layout = "_AdminLayout";
}

<div class="container-fluid py-4">
    <h1 class="mb-4">Pending Claims</h1>
    
    @if (Model.Any())
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Item</th>
                            <th>Claimant</th>
                            <th>Description</th>
                            <th>Submitted</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var claim in Model)
                        {
                            <tr>
                                <td>#@claim.Id</td>
                                <td>
                                    <a asp-controller="Items" asp-action="Details" asp-route-id="@claim.ItemId">
                                        @claim.ItemTitle
                                    </a>
                                </td>
                                <td>
                                    <strong>@claim.ClaimantName</strong>
                                    <br><small class="text-muted">@claim.ClaimantEmail</small>
                                </td>
                                <td>
                                    <span title="@claim.Description">
                                        @(claim.Description.Length > 50 ? claim.Description.Substring(0, 50) + "..." : claim.Description)
                                    </span>
                                </td>
                                <td>@claim.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <a asp-controller="Admin" asp-action="ReviewClaim" asp-route-id="@claim.Id" class="btn btn-primary btn-sm">
                                        <i class="bi bi-eye me-1"></i>Review
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-check-circle fs-1 text-success"></i>
            <h4 class="mt-3">No pending claims</h4>
            <p class="text-muted">All claims have been reviewed.</p>
        </div>
    }
</div>
