@model CampusLostAndFound.Web.Models.DTOs.ItemListViewDto
@{
    ViewData["Title"] = "My Items";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>My Items</h1>
        <a asp-controller="Items" asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Report New Item
        </a>
    </div>

    @if (!Model.Items.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            You haven't reported any items yet.
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var item in Model.Items)
            {
                <div class="col">
                    <div class="card h-100">
                        @if (!string.IsNullOrEmpty(item.PrimaryImagePath))
                        {
                            <img src="@item.PrimaryImagePath" class="card-img-top" alt="@item.Title" style="height: 200px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                <i class="bi bi-image text-muted" style="font-size: 3rem;"></i>
                            </div>
                        }
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="badge @(item.ItemType == CampusLostAndFound.Web.Models.Enums.ItemType.Lost ? "bg-danger" : "bg-success")">
                                    @item.ItemType
                                </span>
                                @switch (item.Status)
                                {
                                    case CampusLostAndFound.Web.Models.Enums.ItemStatus.Active:
                                        <span class="badge bg-primary">Active</span>
                                        break;
                                    case CampusLostAndFound.Web.Models.Enums.ItemStatus.Claimed:
                                        <span class="badge bg-warning text-dark">Claimed</span>
                                        break;
                                    case CampusLostAndFound.Web.Models.Enums.ItemStatus.Resolved:
                                        <span class="badge bg-secondary">Resolved</span>
                                        break;
                                    case CampusLostAndFound.Web.Models.Enums.ItemStatus.Expired:
                                        <span class="badge bg-dark">Expired</span>
                                        break;
                                }
                            </div>
                            <h5 class="card-title">@item.Title</h5>
                            <p class="card-text text-muted small">
                                <i class="bi bi-geo-alt me-1"></i>@item.LocationName
                            </p>
                            <p class="card-text small">
                                <i class="bi bi-tag me-1"></i>@item.CategoryName
                            </p>
                        </div>
                        <div class="card-footer bg-transparent">
                            <div class="d-flex justify-content-between align-items-center">
                                <small class="text-muted">@item.CreatedAt.ToString("MMM dd, yyyy")</small>
                                <a asp-controller="Items" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                    View
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
