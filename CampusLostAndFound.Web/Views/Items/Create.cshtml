@model CreateItemDto
@{
    var itemType = (ItemType?)ViewData["ItemType"] ?? ItemType.Lost;
    ViewData["Title"] = $"Report {itemType} Item";
    var categories = ViewData["Categories"] as List<CategoryDto> ?? new List<CategoryDto>();
    var locations = ViewData["Locations"] as List<LocationDto> ?? new List<LocationDto>();
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header @(itemType == ItemType.Lost ? "bg-danger" : "bg-success") text-white">
                    <h4 class="mb-0">
                        <i class="bi @(itemType == ItemType.Lost ? "bi-exclamation-circle" : "bi-check-circle") me-2"></i>
                        Report @itemType Item
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        <input type="hidden" name="ItemType" value="@((int)itemType)" />
                        
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label">Item Title <span class="text-danger">*</span></label>
                            <input asp-for="Title" class="form-control" placeholder="e.g., Black iPhone 13, Blue Backpack, Silver Keys" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                            <div class="form-text">Provide a brief, descriptive title for the item.</div>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Description <span class="text-danger">*</span></label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Describe the item in detail - color, size, brand, any distinguishing features..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                            <div class="form-text">The more details you provide, the easier it will be to identify the item.</div>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="CategoryId" class="form-label">Category <span class="text-danger">*</span></label>
                                <select asp-for="CategoryId" class="form-select">
                                    <option value="">Select a category</option>
                                    @foreach (var cat in categories)
                                    {
                                        <option value="@cat.Id">@cat.Name</option>
                                    }
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger"></span>
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label asp-for="LocationId" class="form-label">Location <span class="text-danger">*</span></label>
                                <select asp-for="LocationId" class="form-select">
                                    <option value="">Select a location</option>
                                    @foreach (var loc in locations)
                                    {
                                        <option value="@loc.Id">@loc.Name</option>
                                    }
                                </select>
                                <span asp-validation-for="LocationId" class="text-danger"></span>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="LocationDetails" class="form-label">Specific Location Details</label>
                            <input asp-for="LocationDetails" class="form-control" placeholder="e.g., Near the water fountain on the 2nd floor, Table by the window" />
                            <span asp-validation-for="LocationDetails" class="text-danger"></span>
                            <div class="form-text">Any additional details about where the item was @(itemType == ItemType.Lost ? "last seen" : "found").</div>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="DateOccurred" class="form-label">Date @(itemType == ItemType.Lost ? "Lost" : "Found") <span class="text-danger">*</span></label>
                            <input asp-for="DateOccurred" type="date" class="form-control" max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="DateOccurred" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-4">
                            <label class="form-label">Images (Optional)</label>
                            <input type="file" name="images" class="form-control" multiple accept="image/*" />
                            <div class="form-text">Upload up to 5 images of the item. Supported formats: JPG, PNG, GIF, WebP. Max size: 5MB each.</div>
                        </div>
                        
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn @(itemType == ItemType.Lost ? "btn-danger" : "btn-success") btn-lg">
                                <i class="bi bi-send me-1"></i>Submit Report
                            </button>
                            <a asp-controller="Items" asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
